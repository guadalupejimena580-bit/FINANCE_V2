# ── Base de datos Railway MySQL ────────────────────────────────
DB_HOST=your-railway-host.railway.app
DB_PORT=3306
DB_USER=root
DB_PASS=your_db_password
DB_NAME=finance_db

# ── JWT ────────────────────────────────────────────────────────
# Generá un secreto seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REEMPLAZAR_CON_SECRETO_SEGURO_DE_64_CHARS
JWT_EXPIRES_IN=7d

# ── Servidor ───────────────────────────────────────────────────
PORT=3000
